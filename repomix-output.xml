                duration: 1.5,
                repeat: Infinity,
                repeatDelay: 0.5
              }}
            >
              <Sparkles className="h-5 w-5" />
            </motion.div>
          </motion.div>
        </motion.div>
      )}
    </AnimatePresence>
  );
};

export default ConfirmationNotification;
