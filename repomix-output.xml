            <CardContent className="p-6">
                <div className="flex gap-2 mb-6">
                    <Input
                        placeholder="INPUT_NEW_TASK..."
                        value={newTaskTitle}
                        onChange={(e) => setNewTaskTitle(e.target.value)}
                        onKeyDown={(e) => e.key === 'Enter' && addTask(e)}
