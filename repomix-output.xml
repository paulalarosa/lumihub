                </div>
              </div>
            </div>
          </TabsContent>

          <TabsContent value="services">
            <div className="max-w-4xl mx-auto py-8">
              {d.services.length === 0 ? (
                <div className="text-center py-12 border border-neutral-800 bg-[#0a0a0a]">
