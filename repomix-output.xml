                </div>
                <Button variant="ghost" size="sm" onClick={() => signOut()}>
                    <LogOut className="w-4 h-4 mr-2" /> Sair
                </Button>
            </nav>
            <main className="p-4 md:p-6 max-w-7xl mx-auto animate-fade-in">
                <Outlet />
            </main>
        </div>
    );
};
