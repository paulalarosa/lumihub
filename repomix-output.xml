                          isGenerating && m === messages[messages.length - 1]
                        }
                      />
                    )}

                    {/* Content - Elements Protocol Renderer */}
                    <MessageContent
                      message={m}
                      className={cn(
                        'font-sans text-[13px] leading-relaxed',
                        m.role === 'user' ? 'text-zinc-300' : 'text-zinc-200',
                      )}
                    />

                    {/* Tool Invocations - Serialized widgets */}
                    {m.tool_invocations && m.tool_invocations.length > 0 && (
                      <div className="space-y-3 pt-2">
                        {m.tool_invocations.map((ti: any) => (
                          <ToolInvocation key={ti.id} invocation={ti as any} />
