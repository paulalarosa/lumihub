                                        className="h-6 w-6 text-gray-500 hover:text-white hover:bg-white/10 rounded-none opacity-0 group-hover:opacity-100 transition-opacity"
                                        onClick={() => markAsRead(notification.id)}
                                        title={t("btn_mark_read")}
                                    >
