  "scripts": {
    "preinstall": "npx only-allow npm",
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "build": "npm run sitemap && tsc && vite build && node -e \"const fs = require('fs'); fs.copyFileSync('dist/index.html', 'dist/404.html');\"",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && aws s3 sync dist/ s3://khaos-kontrol-site --delete --no-cli-pager && aws cloudfront create-invalidation --distribution-id E2QFIPXMPI0HCW --paths \"/*\" --no-cli-pager",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-gen": "supabase gen types typescript --local > src/integrations/supabase/types.ts",
    "db:link:dev": "npx supabase link --project-ref nqufpfpqtycxxqtnkkfh",
    "db:link:prod": "npx supabase link --project-ref pymdkngcpbmcnayxieod",
    "db:push:dev": "npm run db:link:dev && npx supabase db push",
    "db:push:prod": "npm run db:link:prod && npx supabase db push",
    "functions:deploy:dev": "npm run db:link:dev && npx supabase functions deploy",
    "functions:deploy:prod": "npm run db:link:prod && npx supabase functions deploy",
    "types:generate": "supabase gen types typescript --local > src/integrations/supabase/types.ts",
    "types:prod": "supabase gen types typescript --project-id pymdkngcpbmcnayxieod > src/integrations/supabase/types.ts"
  },
