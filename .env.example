# Copia este arquivo para .env.development (aponta para o projeto `khaos-kontrol-dev`)
# e .env.production (aponta para `khaos-kontrol-prod`).
#
# Nunca commitar chaves reais — .env.* estão no .gitignore, apenas este
# .env.example é versionado.

# Supabase — obrigatório
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-jwt>

# Google Maps Places API — usado nos formulários de endereço
VITE_GOOGLE_MAPS_API_KEY=

# Google API key (Calendar, People, etc.) — opcional
VITE_GOOGLE_API_KEY=

# VAPID public key — Web Push. Precisa bater com o secret da Edge Function.
VITE_VAPID_PUBLIC_KEY=

# Resend — apenas para previews locais. Em produção o envio é feito pelas
# Edge Functions via secret OFFICIAL_EMAIL_KHAOS. Deixe vazio aqui.
VITE_RESEND_API_KEY=
VITE_RESEND_FROM=no-reply@khaoskontrol.com.br
VITE_REPLY_TO=khaoskontrol07@gmail.com

# Stripe — opcional. Apenas a publishable key (chave pública). NÃO coloque a secret.
VITE_STRIPE_PUBLISHABLE_KEY=

# Sentry — opcional, ativo apenas em builds de produção
VITE_SENTRY_DSN=

# Google OAuth Client ID — opcional, Sign-in with Google
VITE_GOOGLE_CLIENT_ID=
